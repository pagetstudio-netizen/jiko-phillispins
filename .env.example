# =============================================
# CONFIGURATION PLESK - Noviqra AI
# Copier ce fichier en .env et remplir les valeurs
# =============================================

# Base de données PostgreSQL
# Option 1 : PostgreSQL Plesk ou hébergé
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE_NAME

# Option 2 : Supabase (si vous utilisez Supabase)
# SUPABASE_DATABASE_URL=postgresql://postgres.XXXX:PASSWORD@aws-1-eu-west-3.pooler.supabase.com:6543/postgres

# Clé secrète de session (IMPORTANT : changer en production !)
SESSION_SECRET=changer-cette-cle-secrete-en-production-abc123

# Environnement
NODE_ENV=production

# Port (Plesk gère automatiquement via la variable PORT)
# Ne pas modifier sauf si nécessaire
PORT=3000
