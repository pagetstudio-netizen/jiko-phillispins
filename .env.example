# Base de données Supabase
SUPABASE_DATABASE_URL=postgresql://postgres.XXXX:PASSWORD@aws-1-eu-west-3.pooler.supabase.com:6543/postgres

# Clé API Supabase (anon)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Session secret (changer en production)
SESSION_SECRET=your-strong-secret-key-here

# Port (Plesk gère automatiquement)
PORT=5000

# Environnement
NODE_ENV=production
