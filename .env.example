# ============================================================
# NOVIQRA AI — Variables d'environnement pour Plesk / Production
# ============================================================
# Sur Plesk : Node.js > Environment Variables (pas besoin de .env).

# --- Base de données -----------------------------------------------------------
# URL de connexion PostgreSQL principale (peut être le pooler Supabase port 6543)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# DIRECT_URL : connexion directe (port 5432) — OBLIGATOIRE si DATABASE_URL
# pointe vers le pooler Supabase (port 6543). Utilisé pour les sessions et migrations.
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# --- Sécurité -----------------------------------------------------------------
# Clé secrète pour chiffrer les cookies de session — changez cette valeur !
SESSION_SECRET=CHANGEZ_CETTE_VALEUR_LONGUE_ET_ALEATOIRE

# --- Environnement ------------------------------------------------------------
NODE_ENV=production

# --- Port ---------------------------------------------------------------------
# Port sur lequel Node.js écoute. Sur Plesk, configurez le Node.js App Port.
PORT=3000

# --- CORS (optionnel) ---------------------------------------------------------
# Si le frontend et le backend sont sur des origines différentes, définissez
# l'URL exacte de votre domaine (sans slash final).
# Exemple : CORS_ORIGIN=https://mondomaine.com
# Laisser vide si tout est servi depuis le même serveur Express.
CORS_ORIGIN=

# --- Cookie sécurisé ----------------------------------------------------------
# Par défaut : true en production. Mettre à "false" UNIQUEMENT si pas de HTTPS.
# FORCE_SECURE_COOKIE=true

# --- Proxy --------------------------------------------------------------------
# Nombre de couches proxy devant Node.js. Laisser vide = trust all (recommandé Plesk).
# TRUST_PROXY=1
